{
  "name": "padaccheda-app",
  "version": "0.1.0",
  "description": "Padaccheda - Sanskrit word division tool (web UI)",
  "type": "module",
  "private": true,
  "scripts": {
    "sync-model": "mkdir -p public/model && cp ../engine/model/space_cnn_v1.json ../engine/model/space_cnn_v1.bin public/model/",
    "predev": "npm run -s sync-model",
    "dev": "vite",
    "prebuild": "npm run -s sync-model",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
