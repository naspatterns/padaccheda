{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "paths": {
      "@engine": ["../engine/src/index.ts"],
      "@engine/*": ["../engine/src/*"]
    }
  },
  "include": ["src", "test", "../engine/src"]
}
